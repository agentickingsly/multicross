# Database — superuser connection string used by the migration runner
DATABASE_URL=postgresql://user:pass@localhost:5432/crossword

# Individual DB connection vars — used by the app pool (pool.ts)
# In production, point these at a least-privilege user (multicross_app)
# that has SELECT/INSERT/UPDATE/DELETE only — no CREATE/DROP/ALTER.
# Leave DB_USER unset to fall back to DATABASE_URL (useful for local dev).
DB_USER=multicross_app
DB_PASSWORD=<generate with: openssl rand -hex 32>
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crossword

# Redis
REDIS_URL=redis://localhost:6379

# Auth — generate with: openssl rand -base64 48
JWT_SECRET=

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# Beta access — remove to open registration to everyone
INVITE_CODE=
